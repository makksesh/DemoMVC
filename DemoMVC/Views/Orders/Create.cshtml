@model DemoMVC.ViewModels.OrderEditViewModel

@{
    ViewData["Title"] = "Добавить заказ";
    bool singleMode = (bool)ViewBag.SingleItemMode;
}

<h2>Добавить заказ</h2>
<hr />

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="OrderStatusId" class="form-label fw-semibold">Статус заказа</label>
                <select asp-for="OrderStatusId" class="form-select" asp-items="ViewBag.OrderStatusId">
                    <option value="">— Выберите статус —</option>
                </select>
                <span asp-validation-for="OrderStatusId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PickupPointId" class="form-label fw-semibold">Адрес пункта выдачи</label>
                <select asp-for="PickupPointId" class="form-select" asp-items="ViewBag.PickupPointId">
                    <option value="">— Выберите пункт выдачи —</option>
                </select>
                <span asp-validation-for="PickupPointId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CreatedAt" class="form-label fw-semibold">Дата заказа</label>
                <input asp-for="CreatedAt" type="date" class="form-control" />
                <span asp-validation-for="CreatedAt" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DeliveryDate" class="form-label">Дата выдачи</label>
                <input asp-for="DeliveryDate" type="date" class="form-control" />
                <span asp-validation-for="DeliveryDate" class="text-danger small"></span>
            </div>

            <h5 class="mt-4 mb-2">Товары в заказе</h5>
            <div id="items-container">
                @for (int i = 0; i < Model.Items.Count; i++)
                {
                    <div class="row g-2 mb-2 order-item-row">
                        <input type="hidden" name="Items[@i].Id" value="@Model.Items[i].Id" />

                        <div class="col-7">
                            <select name="Items[@i].ProductId" class="form-select">
                                <option value="">— Товар —</option>
                                @foreach (var p in (SelectList)ViewBag.Products)
                                {
                                    <option value="@p.Value" selected="@(p.Value == Model.Items[i].ProductId.ToString())">
                                        @p.Text
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-3">
                            <input type="number" name="Items[@i].Quantity"
                                   value="@(Model.Items[i].Quantity < 1 ? 1 : Model.Items[i].Quantity)"
                                   min="1" class="form-control" placeholder="Кол-во" />
                        </div>
                        @if (!singleMode)
                        {
                            <div class="col-2">
                                <button type="button" class="btn btn-outline-danger btn-sm w-100 remove-item-btn">✕</button>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (!singleMode)
            {
                <button type="button" id="add-item-btn" class="btn btn-outline-secondary btn-sm mb-3">
                    + Добавить товар
                </button>
            }

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-success">💾 Добавить заказ</button>
                <a asp-action="Index" class="btn btn-secondary">← Назад к заказам</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    @if (!(bool)ViewBag.SingleItemMode)
    {
        <script>
            (function () {
                const container = document.getElementById('items-container');
                const addBtn    = document.getElementById('add-item-btn');

                // Шаблон строки-продукта берём из первой строки
                function getNextIndex() {
                    return container.querySelectorAll('.order-item-row').length;
                }

                addBtn.addEventListener('click', function () {
                    const idx = getNextIndex();
                    const firstRow = container.querySelector('.order-item-row');
                    const newRow = firstRow.cloneNode(true);

                    // Обновляем индексы в name-атрибутах
                    newRow.querySelectorAll('[name]').forEach(el => {
                        el.name = el.name.replace(/\[\d+\]/, `[${idx}]`);
                        if (el.tagName === 'SELECT') el.value = '';
                        if (el.type === 'number')   el.value = 1;
                        if (el.type === 'hidden')   el.value = '';
                    });

                    container.appendChild(newRow);
                });

                container.addEventListener('click', function (e) {
                    if (e.target.classList.contains('remove-item-btn')) {
                        const rows = container.querySelectorAll('.order-item-row');
                        if (rows.length > 1) {
                            e.target.closest('.order-item-row').remove();
                            // Переиндексируем оставшиеся строки
                            container.querySelectorAll('.order-item-row').forEach((row, i) => {
                                row.querySelectorAll('[name]').forEach(el => {
                                    el.name = el.name.replace(/\[\d+\]/, `[${i}]`);
                                });
                            });
                        }
                    }
                });
            })();
        </script>
    }
}