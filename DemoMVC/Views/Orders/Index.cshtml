@model IEnumerable<DemoMVC.Models.Order>

@{
    ViewData["Title"] = "Заказы";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Заказы</h2>
    @if (User.IsInRole("Администратор"))
    {
        <a asp-action="Create" class="btn btn-success">➕ Добавить заказ</a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <p>Заказов пока нет.</p>
    </div>
}
else
{
    <div class="list-group">
        @foreach (var order in Model)
        {
            <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start p-3">
                <div>
                    <div class="fw-bold">Артикул заказа: @order.Code</div>
                    <div>Статус: @order.OrderStatus?.Name</div>
                    <div class="text-muted">Адрес пункта выдачи: @order.PickupPoint?.Address</div>
                    <div class="text-muted">Дата заказа: @order.CreatedAt.ToString("dd.MM.yyyy")</div>
                </div>
                <div class="text-end d-flex flex-column align-items-end gap-2">
                    <span class="text-muted small">
                        @if (order.DeliveryDate.HasValue)
                        {
                            <span>Дата доставки:</span><br />
                            <strong>@order.DeliveryDate.Value.ToString("dd.MM.yyyy")</strong>
                        }
                        else
                        {
                            <span class="text-muted">Дата доставки не задана</span>
                        }
                    </span>
                    @if (User.IsInRole("Администратор"))
                    {
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">✏️ Редактировать</a>
                            <form asp-action="Delete" asp-route-id="@order.Id" method="post"
                                  onsubmit="return confirm('Удалить заказ @order.Code?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">🗑️ Удалить</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
