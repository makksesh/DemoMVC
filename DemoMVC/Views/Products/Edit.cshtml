@model DemoMVC.Models.Product

@{
    ViewData["Title"] = "Редактировать товар";
}

<h2>Редактировать товар</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            @* ID — только для чтения *@
            <div class="mb-3">
                <label class="form-label">ID товара</label>
                <input type="text" class="form-control" value="@Model.Id" readonly />
                <input type="hidden" asp-for="Id" />
            </div>

            @* Фото товара с предпросмотром *@
            <div class="mb-3">
                <label class="form-label fw-semibold">Фото товара</label>
                <div class="mb-2">
                    @{
                        var currentImg = string.IsNullOrEmpty(Model.ImagePath)
                            ? Url.Content("~/img/picture.png")
                            : Url.Content("~/img/products/" + Model.ImagePath);
                    }
                    <img id="previewImg" src="@currentImg"
                         alt="Текущее фото"
                         style="width:150px;height:100px;object-fit:cover;border:1px solid #ccc;border-radius:4px;" />
                </div>
                <input type="file" name="imageFile" id="imageFile" accept="image/*" class="form-control"
                       onchange="previewImage(this)" />
                <input asp-for="ImagePath" type="hidden" />
                <div class="form-text">Загрузите новое фото, чтобы заменить текущее (300×200 пикс.).</div>
            </div>

            <div class="mb-3">
                <label asp-for="Article" class="form-label fw-semibold">Артикул</label>
                <input asp-for="Article" class="form-control" />
                <span asp-validation-for="Article" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Наименование</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label fw-semibold">Категория</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ManufacturerId" class="form-label fw-semibold">Производитель</label>
                <select asp-for="ManufacturerId" class="form-select" asp-items="ViewBag.ManufacturerId"></select>
                <span asp-validation-for="ManufacturerId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SupplierId" class="form-label fw-semibold">Поставщик</label>
                <select asp-for="SupplierId" class="form-select" asp-items="ViewBag.SupplierId"></select>
                <span asp-validation-for="SupplierId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Price" class="form-label fw-semibold">Цена (₽)</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Price" class="text-danger small"></span>
                <div class="form-text">Цена не может быть отрицательной.</div>
            </div>
            <div class="mb-3">
                <label asp-for="UnitOfMeasure" class="form-label fw-semibold">Единица измерения</label>
                <select asp-for="UnitOfMeasure" class="form-select" asp-items="ViewBag.UnitOfMeasure"></select>
                <span asp-validation-for="UnitOfMeasure" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Quantity" class="form-label fw-semibold">Количество на складе</label>
                <input asp-for="Quantity" class="form-control" type="number" min="0" />
                <span asp-validation-for="Quantity" class="text-danger small"></span>
                <div class="form-text">Количество не может быть отрицательным.</div>
            </div>
            <div class="mb-3">
                <label asp-for="Discount" class="form-label">Скидка (%)</label>
                <input asp-for="Discount" class="form-control" type="number" step="0.01" min="0" max="100" />
                <span asp-validation-for="Discount" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">💾 Сохранить изменения</button>
                <a asp-action="Index" class="btn btn-secondary">← Назад к списку</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewImg').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
