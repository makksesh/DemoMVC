@model DemoMVC.Models.Product

@{
    ViewData["Title"] = "Добавить товар";
}

<h2>Добавить товар</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            @* Фото товара *@
            <div class="mb-3">
                <label class="form-label fw-semibold">Фото товара</label>
                <div class="mb-2">
                    <img id="previewImg"
                         src="@Url.Content("~/img/picture.png")"
                         alt="Предпросмотр"
                         style="width:150px;height:100px;object-fit:cover;border:1px solid #ccc;border-radius:4px;" />
                </div>
                <input type="file" name="imageFile" id="imageFile" accept="image/*" class="form-control"
                       onchange="previewImage(this)" />
                <div class="form-text">Рекомендуемый размер: 300×200 пикселей.</div>
            </div>

            <div class="mb-3">
                <label asp-for="Article" class="form-label fw-semibold">Артикул</label>
                <input asp-for="Article" class="form-control" placeholder="Введите артикул" />
                <span asp-validation-for="Article" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Наименование</label>
                <input asp-for="Name" class="form-control" placeholder="Введите наименование" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label fw-semibold">Категория</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                    <option value="">— Выберите категорию —</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ManufacturerId" class="form-label fw-semibold">Производитель</label>
                <select asp-for="ManufacturerId" class="form-select" asp-items="ViewBag.ManufacturerId">
                    <option value="">— Выберите производителя —</option>
                </select>
                <span asp-validation-for="ManufacturerId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SupplierId" class="form-label fw-semibold">Поставщик</label>
                <select asp-for="SupplierId" class="form-select" asp-items="ViewBag.SupplierId">
                    <option value="">— Выберите поставщика —</option>
                </select>
                <span asp-validation-for="SupplierId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Price" class="form-label fw-semibold">Цена (₽)</label>
                <input asp-for="Price" class="form-control"
                       placeholder="0.00" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="MeasurementId" class="form-label fw-semibold">Единица измерения</label>
                <select asp-for="MeasurementId" class="form-select" asp-items="ViewBag.UnitOfMeasure">
                    <option value="">— Выберите единицу измерения —</option>
                </select>
                <span asp-validation-for="MeasurementId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Quantity" class="form-label fw-semibold">Количество на складе</label>
                <input asp-for="Quantity" class="form-control"
                       placeholder="0" />
                <span asp-validation-for="Quantity" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Discount" class="form-label">Скидка (%)</label>
                <input asp-for="Discount" class="form-control"
                       placeholder="0" />
                <span asp-validation-for="Discount" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">💾 Добавить товар</button>
                <a asp-action="Index" class="btn btn-secondary">← Назад к списку</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('previewImg').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
