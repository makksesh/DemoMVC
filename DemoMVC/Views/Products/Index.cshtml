@model IEnumerable<DemoMVC.Models.Product>

@{
    ViewData["Title"] = "Список товаров";
}

<h2>Список товаров</h2>

<div class="product-list">
    @foreach (var item in Model)
    {
        var hasDiscount = item.Discount > 0;
        var bigDiscount = item.Discount > 17;
        var outOfStock = item.Quantity <= 0;

        var cardClass = "product-card";
        if (outOfStock)
        {
            cardClass += " product-card-outofstock";   // голубой фон
        }
        else if (bigDiscount)
        {
            cardClass += " product-card-bigdicount";   // #FFDEAD
        }

        <div class="@cardClass">
            <div class="product-photo">
                @{
                    var imgPath = string.IsNullOrEmpty(item.ImagePath)
                        ? Url.Content("~/img/picture.png")   // заглушка
                        : Url.Content("~/img/products/" + item.ImagePath);
                }
                <img src="@imgPath"
                     alt="Фото товара"
                     onerror="this.onerror=null; this.src='@Url.Content("~/img/picture.png")';" />
            </div>

            <div class="product-info">
                <div class="product-header">
                    <span class="product-category">@item.Category?.Name</span>
                    <span class="product-name">@item.Name</span>
                </div>
                <div>Описание: @item.Description</div>
                <div>Производитель: @item.Manufacturer?.Name</div>
                <div>Поставщик: @item.Supplier?.Name</div>
                <div>Единица измерения: @item.UnitOfMeasure</div>
                <div>Количество на складе: @item.Quantity</div>

                <div class="product-price">
                    @if (hasDiscount)
                    {
                        <span class="old-price">@item.Price.ToString("0.00") ₽</span>
                        <span class="new-price">
                            @{
                                var newPrice = item.Price * (1 - item.Discount / 100m);
                            }
                            @newPrice.ToString("0.00") ₽
                        </span>
                    }
                    else
                    {
                        <span class="new-price">@item.Price.ToString("0.00") ₽</span>
                    }
                </div>
            </div>

            <div class="product-discount">
                <span>@item.Discount %</span>
            </div>
        </div>
    }
</div>