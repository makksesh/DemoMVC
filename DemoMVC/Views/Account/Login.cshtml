@model DemoMVC.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Вход";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="login-card">
        <div class="login-logo">
            <img src="~/img/logo.png" alt="Логотип"
                 height="72" width="72"
                 style="object-fit: contain;"
                  />
        </div>
        

        @if (ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
        {
            <div class="login-errors">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p>@error.ErrorMessage</p>
                }
            </div>
        }

        <form asp-action="Login" method="post">
            <input asp-for="ReturnUrl" type="hidden" />

            <div class="login-field">
                <label asp-for="Login" class="login-label"></label>
                <input asp-for="Login" class="login-input" autocomplete="username" />
                <span asp-validation-for="Login" class="login-validation"></span>
            </div>

            <div class="login-field">
                <label asp-for="Password" class="login-label"></label>
                <input asp-for="Password" class="login-input" autocomplete="current-password" />
                <span asp-validation-for="Password" class="login-validation"></span>
            </div>

            <button type="submit" class="login-btn-primary">Войти</button>
        </form>

        <form asp-action="Guest" method="get" style="margin-top: 8px;">
            <button type="submit" class="login-btn-secondary">Войти как гость</button>
        </form>

    </div>
</div>

<style>
    
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
